# Supabase — get these from supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Anthropic Claude API — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...your-api-key

# App URL — use http://localhost:3000 for local dev, your Railway domain for production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to production on Railway
NODE_ENV=development
